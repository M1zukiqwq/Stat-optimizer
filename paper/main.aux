\newlabel{sec:mcv-validation}{{4.2}{10}{Statistics-Format Interface Validation}{subsection.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Statistics-format interface validation on PostgreSQL-style MCV statistics. (a) Round-trip residual-quantile error stays at machine precision across all tested distributions. (b) Conversion overhead remains far below the planning-time budget in (D2) on typical PostgreSQL configurations. (c) Threshold sensitivity is mild near PostgreSQL's default setting (1\%) and increases gradually only at larger thresholds.}}{10}{figure.caption.14}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:mcv-validation}{{1}{10}{Statistics-format interface validation on PostgreSQL-style MCV statistics. (a) Round-trip residual-quantile error stays at machine precision across all tested distributions. (b) Conversion overhead remains far below the planning-time budget in (D2) on typical PostgreSQL configurations. (c) Threshold sensitivity is mild near PostgreSQL's default setting (1\%) and increases gradually only at larger thresholds}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Main Results: Q-Error vs.\ Drift Intensity}{11}{subsection.4.3}\protected@file@percent }
\newlabel{sec:main_results}{{4.3}{11}{Main Results: Q-Error vs.\ Drift Intensity}{subsection.4.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Q-Error comparison across drift intensities ($\downarrow $ better). OASIS trained on $q \in \{1,3,5,10,15,20\}$ (6000 samples total). Bold = best per row; ``+\%'' = improvement over the stale prior.}}{11}{table.caption.15}\protected@file@percent }
\newlabel{tab:qerror}{{1}{11}{Q-Error comparison across drift intensities ($\downarrow $ better). OASIS trained on $q \in \{1,3,5,10,15,20\}$ (6000 samples total). Bold = best per row; ``+\%'' = improvement over the stale prior}{table.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Correction performance across drift intensities and initial distributions. The first three panels report Gaussian compound-drift results for $K{=}16$ and $B{=}10$; the fourth panel summarizes Q-Error under unseen initial distributions at $q{=}10$. OASIS achieves up to 62.0\% Q-Error reduction over the stale prior while remaining robust across different starting distributions.}}{12}{figure.caption.16}\protected@file@percent }
\newlabel{fig:ablation}{{2}{12}{Correction performance across drift intensities and initial distributions. The first three panels report Gaussian compound-drift results for $K{=}16$ and $B{=}10$; the fourth panel summarizes Q-Error under unseen initial distributions at $q{=}10$. OASIS achieves up to 62.0\% Q-Error reduction over the stale prior while remaining robust across different starting distributions}{figure.caption.16}{}}
